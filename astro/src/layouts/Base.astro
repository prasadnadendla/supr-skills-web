---
// Root HTML layout — fonts, meta, and the global stylesheet.
// Per plan §5.1.1, Astro emits this as static HTML; only the React island
// inside the page (<App client:load />) ships JS.

import '@/styles/global.css';
import { brandConfig } from '@/config/brand.config';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${brandConfig.name} — ${brandConfig.tagline}`,
  description = "World-class free courses with an always-on AI buddy that watches the lecture with you and brings in a human expert when needed.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Fonts — preconnect + a single combined family request to keep CLS low */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,400;12..96,500;12..96,600;12..96,700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="font-display text-cream bg-ink antialiased overflow-hidden">
    <slot />
  </body>
</html>
